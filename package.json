  "private": true,
  "description": "A fast, installable PWA kaomoji picker — copy & paste Japanese emoticons, text faces, emoji and symbols.",
  "homepage": "https://kaomoji.fyi",
  "repository": { "type": "git", "url": "https://github.com/gfrmin/kaomoji" },
