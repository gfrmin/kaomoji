  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "migrate": "node scripts/migrate.mjs",
    "decompose": "node scripts/decompose.mjs",
    "galleries": "node scripts/build-galleries.mjs",
