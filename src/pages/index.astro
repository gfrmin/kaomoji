---
import Layout from "../layouts/Layout.astro";
import Picker from "../components/Picker.jsx";
import { SITE } from "../consts.js";
import { categories, items, pageTags } from "../data/index.js";

const popularTags = pageTags.slice(0, 40);
const initial = { kind: "category", id: categories[0].id, label: categories[0].name };

// Category sticker colors — rotate by index for chip borders (matches --c0..--c6).
const CAT_COLORS = ["#ff9a8b", "#ffcf6b", "#97d8b0", "#9cc4f0", "#c4a9e8", "#ffb3c8", "#f0b98a"];

const title = "Kaomoji ( ͡° ͜ʖ ͡°) — Copy & Paste Japanese Emoticons, Text Faces & Emoji";
const description = `The fast, installable kaomoji picker. Search and copy ${items.length}+ Japanese emoticons, cute text faces, emoji and symbols — one tap to copy, works offline.`;

const jsonld = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "Kaomoji",
      url: SITE,
      potentialAction: {
        "@type": "SearchAction",
        target: { "@type": "EntryPoint", urlTemplate: `${SITE}/t/{search_term_string}` },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "WebApplication",
      name: "Kaomoji Picker",
      url: SITE,
      applicationCategory: "UtilitiesApplication",
      operatingSystem: "Any",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    },
  ],
};
---

<Layout title={title} description={description} jsonld={jsonld}>
  <section class="page-head">
    <h1>Kaomoji — Japanese Emoticons & Text Faces ＼(＾▽＾)／</h1>
    <p class="lede">
      Search, tap, paste. {items.length}+ kaomoji, cute text faces, emoji and symbols —
      copied to your clipboard with a single tap. Right-click to ⭐ favourite. Install it
      and it works offline.
    </p>
  </section>

  <Picker client:load initial={initial} showBook />

  <h2 class="section-title">Browse the whole book</h2>
  <nav class="chips" aria-label="Categories">
    {categories.map((c, i) => (
      <a href={`/kaomoji/${c.id}/`} style={`border-color:${CAT_COLORS[i % CAT_COLORS.length]}`}>
        <span class="ic">{c.icon}</span>{c.name} <span class="count">{(items.filter((i) => i.category === c.id)).length}</span>
      </a>
    ))}
  </nav>

  <h2 class="section-title">Crowd favourites</h2>
  <nav class="chips" aria-label="Popular tags">
    {popularTags.map((t) => (
      <a href={`/t/${t.slug}/`}><span class="g">{t.items[0]?.value}</span>{t.tag} <span class="count">{t.items.length}</span></a>
    ))}
    <a href="/tags/">all {pageTags.length} tags →</a>
  </nav>
</Layout>
