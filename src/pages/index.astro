---
import Layout from "../layouts/Layout.astro";
import Picker from "../components/Picker.jsx";
import { SITE } from "../consts.js";
import { categories, items, pageTags, getItemsByCategory } from "../data/index.js";
import { groupedCategories, categoryColor } from "../data/categoryGroups.js";

// Popular tags with a DISTINCT example glyph each — pick the first item whose glyph
// no earlier chip already used, so the cloud doesn't repeat the same kaomoji.
const usedGlyphs = new Set();
const popularTags = pageTags.slice(0, 40).map((t) => {
  const rep = t.items.find((i) => !usedGlyphs.has(i.value)) || t.items[0];
  if (rep) usedGlyphs.add(rep.value);
  return { tag: t.tag, slug: t.slug, count: t.items.length, glyph: rep?.value };
});
const initial = { kind: "category", id: categories[0].id, label: categories[0].name };

// Categories = the browse spine, grouped by kind (Moods / Things & actions / Symbols).
const groups = groupedCategories(categories);
const colorOf = (id) => categoryColor(categories, id);

const title = "Kaomoji ( ͡° ͜ʖ ͡°) — Copy & Paste Japanese Emoticons, Text Faces & Emoji";
const description = `The fast, installable kaomoji picker. Search and copy ${items.length}+ Japanese emoticons, cute text faces, emoji and symbols — one tap to copy, works offline.`;

// Head-term "People Also Ask" coverage — general kaomoji questions, distinct
// from the per-category FAQs. Rendered visibly below + emitted as FAQPage.
const homeFaqs = [
  {
    q: "What is a kaomoji?",
    a: "A kaomoji (顔文字, “face characters”) is a Japanese emoticon built from text symbols — like (＾▽＾) or ¯\\_(ツ)_/¯ — read upright, without tilting your head the way you do for a Western :) smiley. They use characters from many scripts to draw expressive faces and poses.",
  },
  {
    q: "How do I copy and paste a kaomoji?",
    a: "Tap any kaomoji on this page and it's copied to your clipboard instantly — then paste it into Discord, Instagram, TikTok, texts or docs. Use the search box to find one fast, and right-click or long-press to save favourites to your book.",
  },
  {
    q: "Do kaomoji work on iPhone, Android and everywhere else?",
    a: "Yes. Kaomoji are plain Unicode text, not images, so they paste and display on iOS, Android, Windows, Mac and the web with no app or special keyboard. A few rare glyphs may fall back to a slightly different font on some devices, but the face still reads the same.",
  },
  {
    q: "What's the difference between kaomoji, emoji and emoticons?",
    a: "Emoticons are simple sideways faces like :-). Emoji are the coloured picture characters like 😊. Kaomoji are the Japanese style — horizontal text faces like (｡♥‿♥｡) that don't need rotating and can be far more expressive. This picker has all three.",
  },
];
const faqPage = {
  "@type": "FAQPage",
  mainEntity: homeFaqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const jsonld = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "Kaomoji",
      url: SITE,
      potentialAction: {
        "@type": "SearchAction",
        target: { "@type": "EntryPoint", urlTemplate: `${SITE}/t/{search_term_string}` },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "WebApplication",
      name: "Kaomoji Picker",
      url: SITE,
      applicationCategory: "UtilitiesApplication",
      operatingSystem: "Any",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    },
    faqPage,
  ],
};
---

<Layout title={title} description={description} jsonld={jsonld}>
  <section class="page-head">
    <h1>Kaomoji — Japanese Emoticons & Text Faces ＼(＾▽＾)／</h1>
    <p class="lede">
      Search, tap, paste. {items.length}+ kaomoji, cute text faces, emoji and symbols —
      copied to your clipboard with a single tap. Right-click or long-press to ⭐ favourite —
      or tap the ☆ on any sticker in your book. Install it and it works offline.
    </p>
  </section>

  <Picker client:load initial={initial} showBook />

  <p class="browse-intro" id="categories">Browse by category — or search above for anything specific.</p>
  {groups.map((g) => (
    <>
      <h2 class="section-title">{g.label}</h2>
      <nav class="chips" aria-label={g.label}>
        {g.categories.map((c) => (
          <a href={`/kaomoji/${c.id}/`} style={`border-color:${colorOf(c.id)}`}>
            <span class="ic">{c.icon}</span>{c.name} <span class="count">{getItemsByCategory(c.id).length}</span>
          </a>
        ))}
      </nav>
    </>
  ))}

  <h2 class="section-title">Popular searches</h2>
  <nav class="chips" aria-label="Popular tags">
    {popularTags.map((t) => (
      <a href={`/t/${t.slug}/`}><span class="g">{t.glyph}</span>{t.tag} <span class="count">{t.count}</span></a>
    ))}
    <a href="/tags/">all {pageTags.length} tags →</a>
  </nav>

  <section class="faq">
    <h2 class="section-title">Frequently asked</h2>
    {homeFaqs.map((f) => (
      <details>
        <summary>{f.q}</summary>
        <p>{f.a}</p>
      </details>
    ))}
  </section>
</Layout>
