---
import { ClientRouter } from "astro:transitions";
import SEO from "../components/SEO.astro";
import Chrome from "../components/Chrome.jsx";
import "../styles/global.css";

const { title, description, image, type, jsonld } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#fdf6ea" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <!-- Self-hosted woff2 subsets (Latin UI fonts, used above the fold). The JP
         glyph subset is not preloaded — local() satisfies it on JP-equipped
         devices, and font-display:swap renders glyphs via system fonts meanwhile. -->
    <link rel="preload" href="/fonts/Nunito-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Fredoka-600.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      // Capture the install prompt as early as possible. Guarded so the window
      // listeners aren't stacked when View Transitions re-run head scripts.
      (function () {
        if (window.__kaomojiInstallInit) return;
        window.__kaomojiInstallInit = true;
        window.__installPrompt = null;
        window.addEventListener("beforeinstallprompt", function (e) {
          e.preventDefault();
          window.__installPrompt = e;
          window.dispatchEvent(new Event("installpromptready"));
        });
        window.addEventListener("appinstalled", function () {
          window.__installPrompt = null;
          window.dispatchEvent(new Event("installpromptready"));
        });
      })();
    </script>
    <SEO title={title} description={description} image={image} type={type} jsonld={jsonld} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <header class="site-header">
      <a href="/" class="brand" aria-label="Kaomoji home">
        <span>Kaomoji</span><span class="jp">顔文字</span>
      </a>
      <nav aria-label="Primary">
        <a href="/kaomoji/happy">Happy</a>
        <a href="/kaomoji/kawaii">Kawaii</a>
        <a href="/kaomoji/emoji">Emoji</a>
      </nav>
      <Chrome client:load />
    </header>

    <main id="main-content" class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Tap to copy · right-click / long-press to ⭐ favourite ·
        <a href="/">all categories</a> · <a href="/tags/">all tags</a> · <a href="/about/">about</a>
      </p>
      <p>Kaomoji 顔文字 — copy &amp; paste Japanese emoticons, text faces, emoji and symbols.</p>
      <p class="site-credit">just another project by <a href="https://gfrm.in" rel="noopener">Guy Freeman</a> © 2026</p>
    </footer>
  </body>
</html>
